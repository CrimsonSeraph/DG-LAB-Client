/* ========== 全局基础样式 ========== */
QWidget[type="main_page"][mode="night"] {
    background: qlineargradient(x1: 0, y1: 0, x2: 1, y2: 1,
                                stop: 0 rgba(44, 62, 80, 1),
                                stop: 1 rgba(26, 37, 47, 1));
}

/* 玻璃拟态容器 */
QWidget[type="glassmorphism"][mode="night"] {
    background-color: rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 12px;
}

/* 导航按钮 */
QPushButton[type="nav_btn"][mode="night"] {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 rgba(58, 90, 126, 1),
                                stop: 1 rgba(42, 74, 110, 1));
    border: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: bold;
    color: rgba(224, 224, 224, 1);
    padding: 8px 12px;
}
QPushButton[type="nav_btn"][mode="night"]:hover {
    background: rgba(74, 106, 142, 1);
}
QPushButton[type="nav_btn"][mode="night"]:pressed {
    background: rgba(26, 58, 94, 1);
}

/* 操作按钮 */
QPushButton[type="action_btn"][mode="night"] {
    background: rgba(44, 62, 80, 1);
    border: 1px solid rgba(90, 110, 126, 1);
    border-radius: 6px;
    font-size: 14px;
    font-weight: bold;
    color: rgba(224, 224, 224, 1);
    padding: 6px 12px;
}
QPushButton[type="action_btn"][mode="night"]:hover {
    background: rgba(58, 90, 126, 1);
}
QPushButton[type="action_btn"][mode="night"]:pressed {
    background: rgba(26, 42, 62, 1);
}

/* 标题文字 */
QLabel[type="title"][mode="night"] {
    font-size: 20px;
    font-weight: bold;
    color: rgba(240, 240, 240, 1);
    background: transparent;
    qproperty-alignment: AlignCenter;
}

/* 普通标签 */
QLabel[type="label"][mode="night"] {
    font-size: 14px;
    color: rgba(224, 224, 224, 1);
    background: transparent;
    qproperty-alignment: AlignLeft | AlignVCenter;
}

/* 图片标签 */
QLabel[type="image"][mode="night"] {
    background: rgba(0, 0, 0, 0.5);
    border-radius: 40px;
    font-size: 16px;
    font-weight: bold;
    color: rgba(244, 208, 63, 1);
    qproperty-alignment: AlignCenter;
}

/* 输入框 */
QLineEdit[type="input"][mode="night"] {
    background: rgba(44, 62, 80, 1);
    border: 1px solid rgba(90, 110, 126, 1);
    border-radius: 4px;
    padding: 4px 8px;
    font-size: 14px;
    color: rgba(224, 224, 224, 1);
}
QLineEdit[type="input"][mode="night"]:focus {
    border: 1px solid rgba(108, 142, 191, 1);
    background: rgba(58, 90, 126, 1);
}

/* 调试日志框 */
QTextEdit[type="debug_log"][mode="night"] {
    background: rgba(30, 30, 30, 1);
    color: rgba(212, 212, 212, 1);
    font-family: Consolas, monospace;
    font-size: 12px;
    border: 1px solid rgba(62, 62, 62, 1);
    border-radius: 6px;
}

/* 滚动区域 */
QScrollArea[type="scrollarea"][mode="night"] {
    background: transparent;
    border: none;
}

/* 堆叠窗口 */
QStackedWidget[type="stacked"][mode="night"] {
    background: transparent;
}

/* 通道面板 */
QWidget[type="channel_panel"][mode="night"] {
    background: rgba(0, 0, 0, 0.3);
    border-radius: 8px;
    padding: 5px;
}

/* 端口面板 */
QWidget[type="port_panel"][mode="night"] {
    background: rgba(0, 0, 0, 0.4);
    border-radius: 8px;
}

/* 按钮栏 */
QWidget[type="button_bar"][mode="night"] {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 8px;
}

/* 子面板 */
QWidget[type="sub_panel"][mode="night"] {
    background: transparent;
}

/* 波形控件 */
SampledWaveformWidget[type="waveform"][mode="night"] {
    background: rgba(10, 10, 10, 1);
    border-radius: 6px;
}
